{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "jsx": "react-jsx",

    "types": ["node", "vite/client"],

    "strict": true,
    "skipLibCheck": true,

    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "noEmit": true
  },
  "include": [
    "src",
    "api",
    "types",
    "vite.config.ts"
  ]
}